---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Feedback sent | Autism Signals"
  description="Confirmation page for feedback sent through Autism Signals."
>
  <main class="page-shell content-shell">
    <section class="content-card content-card--centered">
      <p class="eyebrow eyebrow--soft">Feedback sent</p>
      <h1>Thank you.</h1>
      <p class="content-intro">
        Your message was submitted. That helps a lot, especially when the site is still growing.
      </p>
      <div class="hero-actions hero-actions--centered">
        <a class="button-link button-link--primary" href="/">Back to the self-check</a>
        <a class="button-link button-link--secondary" href="/about/">About Autism Signals</a>
      </div>
    </section>
  </main>
</BaseLayout>
